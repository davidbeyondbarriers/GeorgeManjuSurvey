# ── Frontend (baked at Vite build time — set BEFORE npm run build) ─────────────

# URL of the API server.
# Leave empty ("") to use same-origin requests (production Docker / ECS setup
# where Express serves both the API and the built frontend on the same port).
# Set to http://localhost:3000 when running the Vite dev server separately from Docker.
VITE_API_URL=

# PostHog analytics key (optional — omit or leave empty to disable analytics)
VITE_POSTHOG_KEY=

# ── API server (runtime — read by Node.js, not Vite) ──────────────────────────

# PostgreSQL connection string.
# Docker Compose local dev: postgres://survey:survey@localhost:5432/survey
# AWS RDS production:       postgres://<user>:<pass>@<rds-endpoint>:5432/survey
DATABASE_URL=postgres://survey:survey@localhost:5432/survey

# HTTP port for the Express API server
PORT=3000

# Node environment — set to "production" in AWS ECS task definition
NODE_ENV=development

# CORS allowed origin for the survey frontend.
# Dev: http://localhost:5200 (Vite dev server)
# Prod: https://your-survey-domain.com
CORS_ORIGIN=http://localhost:5200
